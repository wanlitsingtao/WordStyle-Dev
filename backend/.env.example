# WordStyle Backend 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ==================== 应用配置 ====================
APP_NAME=WordStyle Pro
APP_VERSION=1.0.0
DEBUG=false

# ==================== 数据库配置 ====================
# Supabase PostgreSQL 连接字符串
# 格式: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:your_password@db.xxxxx.supabase.co:5432/postgres

# Redis 配置(可选)
REDIS_URL=redis://localhost:6379/0

# ==================== JWT认证配置 ====================
# 密钥生成: https://randomkeygen.com
# 至少32个字符的随机字符串
SECRET_KEY=your-secret-key-change-this-in-production

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== CORS配置 ====================
# 允许的前端域名,多个用逗号分隔
ALLOWED_ORIGINS=https://*.streamlit.app,https://your-domain.com

# ==================== 文件上传配置 ====================
UPLOAD_DIR=/tmp/uploads
MAX_FILE_SIZE=52428800  # 50MB

# ==================== 支付配置(后期填写) ====================
# 微信支付
WECHAT_APP_ID=your_wechat_app_id
WECHAT_MCH_ID=your_wechat_mch_id
WECHAT_API_KEY=your_wechat_api_key
WECHAT_NOTIFY_URL=https://your-domain.com/api/payments/wechat/callback

# 支付宝
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payments/alipay/callback
