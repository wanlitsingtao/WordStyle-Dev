# =====================================================
# WordStyle 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# =====================================================

# ==================== Supabase 配置 ====================
# 启用 Supabase 模式（true/false）
USE_SUPABASE=true

# Supabase 数据库连接字符串（使用连接池器，端口 6543）
# 格式: postgresql://postgres.{project_id}:{password}@aws-{region}.pooler.supabase.com:6543/postgres
# 注意: 如果密码包含特殊字符(@, #, $, %, &, =, +, ?)，需要进行 URL 编码
DATABASE_URL=postgresql://postgres.your_project_id:your_password@aws-region.pooler.supabase.com:6543/postgres

# ==================== 后端 API 配置（可选）====================
# 如果使用 API 模式，填写后端地址
# 留空表示使用直接数据库连接模式
BACKEND_URL=

# ==================== 其他配置（可选）====================
# 调试模式（true/false）
DEBUG=false

# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO
